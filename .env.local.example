# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OAuth redirect (musí odpovídat URL v Supabase → Authentication → URL Configuration)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapy.cz REST API (geocoding / našeptávač lokality)
NEXT_PUBLIC_MAPY_CZ_API_KEY=your-api-key

# Supabase service role — server-only (poptávkový formulář, lookup e-mailu zadavatele)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — odesílání poptávek
RESEND_API_KEY=re_...
INQUIRY_FROM_EMAIL=HobbyUserMarket <onboarding@resend.dev>

# AI moderace — pouze v Supabase Edge Function secrets (NE do Next.js):
# supabase secrets set GEMINI_API_KEY=...
# volitelně: GEMINI_MODEL=gemini-2.5-flash  (default v kódu, pokud secret chybí)
# volitelně fallback: OPENAI_API_KEY=...