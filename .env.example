# Next.js / Vercel — veřejné klíče (NE Edge secrets)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---
# Supabase Edge Function secrets (nastav přes Dashboard nebo CLI, ne sem do gitu):
#   npx supabase secrets set SIGHTENGINE_API_USER=...
#   npx supabase secrets set SIGHTENGINE_API_SECRET=...
#   npx supabase secrets set GEMINI_API_KEY=...
#   npx supabase secrets set OPENAI_API_KEY=...   # volitelný fallback
#
# Moderace běží na Edge Function moderate-listing — tyto klíče do .env.local nepatří.
